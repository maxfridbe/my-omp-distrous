{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "console_title_template": "{{ if .Root }}root @ {{ end }}{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#4F70BA",
          "foreground": "#FFFFFF",
          "leading_diamond": "",
          "style": "diamond",
          "template": "<b>{{ if or .Env.DISTROBOX_ENTER_PATH .Env.CONTAINER_ID }} {{ end }}  NIXOS </b>",
          "type": "os"
        },
        {
          "background": "#7EB5E1",
          "foreground": "#000000",
          "powerline_symbol": "",
          "style": "powerline",
          "template": "<b>  {{ .Name }} </b>",
          "type": "shell"
        },
        {
          "background": "#3E6DD8",
          "foreground": "#FFFFFF",
          "powerline_symbol": "",
          "style": "powerline",
          "template": "<b>  root </b>",
          "type": "root"
        },
        {
          "type": "cmake",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#E8EAEE",
          "background": "#1E9748",
          "template": "<b>   cmake {{ .Full }} </b>"
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "",
          "properties": {
            "display_mode": "context"
          },
          "foreground": "#000000",
          "foreground_templates": [
            "{{ if .Venv }}#FFFFFF{{ end }}"
          ],
          "background": "#EBFF3B",
          "background_templates": [
            "{{ if .Venv}}#356C9C{{ end }}"
          ],
          "template": " <b> {{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}</b> "
        },
        {
          "type": "go",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#000000",
          "background": "#7FD5EA",
          "template": "<b> ‭ {{ .Full }} </b>"
        },
        {
          "type": "rust",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#e2f3ff",
          "background": "#684e3d",
          "template": "  {{ .Full }} "
        },
        {
          "background": "#D53010",
          "foreground": "#FFFFFF",
          "powerline_symbol": "",
          "properties": {
            "branch_icon": " ",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "fetch_worktree_count": true
          },
          "style": "powerline",
          "template": "<b> {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<#CAEBE1>  {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }} </b>",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "#03DE6C",
          "background_templates": [
            "{{ if gt .Code 0 }}#E44141{{ end }}"
          ],
          "foreground": "#000000",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#FFFFFF{{ end }}"
          ],
          "leading_diamond": "",
          "properties": {
            "always_enabled": true
          },
          "style": "diamond",
          "template": "{{ if gt .Code 0 }}{{ else }}{{ end }}",
          "type": "status",
          "trailing_diamond": ""
        },
        {
          "background": "#575656",
          "foreground": "#FFFFFF",
          "properties": {
            "style": "roundrock",
            "threshold": 0
          },
          "style": "diamond",
          "template": "  {{ .FormattedMs }}",
          "trailing_diamond": "",
          "type": "executiontime"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#A1ACC4",
          "style": "plain",
          "template": "╭─",
          "type": "text"
        },
        {
          "foreground": "#9DD447",
          "properties": {
            "time_format": " <#D4A647> 03:04:05 PM</> <#47D49E>|</>  06/01/02  January  Wednesday "
          },
          "style": "plain",
          "template": "{{ .CurrentDate | date .Format }}",
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "type": "prompt",
      "segments": [
        {
          "foreground": "#A1ACC4",
          "style": "plain",
          "template": "│",
          "type": "text"
        },
        {
          "style": "plain",
          "template": "  <#6F8AC7> {{ .UserName }}</> <#47D49E>|</> <#796FC7>󰍹 {{ .HostName }}</>",
          "type": "session"
        }
      ]
    },
    {
      "alignment": "left",
      "newline": true,
      "type": "prompt",
      "segments": [
        {
          "foreground": "#A1ACC4",
          "style": "plain",
          "template": "│",
          "type": "text"
        },
        {
          "leading_diamond": "",
          "properties": {
            "folder_icon": "  ",
            "folder_separator_icon": " <#A1ACC4></> ",
            "home_icon": "",
            "style": "agnoster_short",
            "max_depth": 4,
            "right_format": "<u><b>%s</b></u>",
            "mapped_locations": {
              "~/Videos": " <#A1ACC4></> ",
              "~/Desktop": " <#A1ACC4></> ",
              "~/Documents": " <#A1ACC4></> 󰈙",
              "~/Downloads": " <#A1ACC4></> ",
              "~/Pictures/": " <#A1ACC4></> ",
              "~/Music": " <#A1ACC4></> "
            }
          },
          "style": "diamond",
          "template": "  <#72D95D>{{ if not .Writable }}<#D96A5D> {{ end }}{{ if .RootDir }}{{ else }}{{ .Path }}{{ end }}</> ",
          "type": "path"
        }
      ]
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#A1ACC4",
          "style": "plain",
          "template": "╰─",
          "type": "text"
        },
        {
          "foreground": "#A1ACC4",
          "properties": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "❯ ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "osc99": true,
  "transient_prompt": {
    "background": "transparent",
    "foreground": "#FEF5ED",
    "template": " "
  },
  "secondary_prompt": {
    "background": "transparent",
    "foreground": "#A1ACC4",
    "template": "╰─❯ "
  },
  "version": 3
}