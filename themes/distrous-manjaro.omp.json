{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "console_title_template": "{{ if .Root }}root @ {{ end }}{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#31BD57",
          "foreground": "#000000",
          "leading_diamond": "оӮІ",
          "style": "diamond",
          "template": "<b>{{ if or .Env.DISTROBOX_ENTER_PATH .Env.CONTAINER_ID }}п’ӯ {{ end }} пҢ’ MANJ </b>",
          "type": "os"
        },
        {
          "background": "#7CDC96",
          "foreground": "#000000",
          "powerline_symbol": "оӮ°",
          "style": "powerline",
          "template": "<b> п’ү {{ .Name }} </b>",
          "type": "shell"
        },
        {
          "background": "#258C41",
          "foreground": "#FFFFFF",
          "powerline_symbol": "оӮ°",
          "style": "powerline",
          "template": "<b> пӮң root </b>",
          "type": "root"
        },
        {
          "type": "cmake",
          "style": "powerline",
          "powerline_symbol": "оӮ°",
          "foreground": "#E8EAEE",
          "background": "#1E9748",
          "template": "<b> оҳһ оҳқ cmake {{ .Full }} </b>"
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "оӮ°",
          "properties": {
            "display_mode": "context"
          },
          "foreground": "#000000",
          "foreground_templates": [
            "{{ if .Venv }}#FFFFFF{{ end }}"
          ],
          "background": "#EBFF3B",
          "background_templates": [
            "{{ if .Venv}}#356C9C{{ end }}"
          ],
          "template": " <b>оңј {{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}</b> "
        },
        {
          "type": "go",
          "style": "powerline",
          "powerline_symbol": "оӮ°",
          "foreground": "#000000",
          "background": "#7FD5EA",
          "template": "<b> вҖӯоҳҰ {{ .Full }} </b>"
        },
        {
          "type": "rust",
          "style": "powerline",
          "powerline_symbol": "оӮ°",
          "foreground": "#e2f3ff",
          "background": "#684e3d",
          "template": " оһЁ {{ .Full }} "
        },
        {
          "background": "#D53010",
          "foreground": "#FFFFFF",
          "powerline_symbol": "оӮ°",
          "properties": {
            "branch_icon": " ",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "fetch_worktree_count": true
          },
          "style": "powerline",
          "template": "<b> {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} пҒ„ {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<#CAEBE1> пҒҶ {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }} оӯӢ {{ .StashCount }}{{ end }} </b>",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "#03DE6C",
          "background_templates": [
            "{{ if gt .Code 0 }}#E44141{{ end }}"
          ],
          "foreground": "#000000",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#FFFFFF{{ end }}"
          ],
          "leading_diamond": "оӮІ",
          "properties": {
            "always_enabled": true
          },
          "style": "diamond",
          "template": "{{ if gt .Code 0 }}пҖҚ{{ else }}пҖҢ{{ end }}",
          "type": "status",
          "trailing_diamond": "оӮ°"
        },
        {
          "background": "#575656",
          "foreground": "#FFFFFF",
          "properties": {
            "style": "roundrock",
            "threshold": 0
          },
          "style": "diamond",
          "template": " пү’ {{ .FormattedMs }}",
          "trailing_diamond": "оӮ°",
          "type": "executiontime"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "",
          "style": "plain",
          "template": "в•ӯв”Җ",
          "type": "text"
        },
        {
          "foreground": "#C8D151",
          "properties": {
            "time_format": " <#D19951>пҖ— 03:04:05 PM</> <#C0DC7C>|</> пҒі 06/01/02 п„„ January п…Ӯ Wednesday п„…"
          },
          "style": "plain",
          "template": "{{ .CurrentDate | date .Format }}",
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "type": "prompt",
      "segments": [
        {
          "foreground": "",
          "style": "plain",
          "template": "в”Ӯ",
          "type": "text"
        },
        {
          "style": "plain",
          "template": "  <#51D173>пҖҮ {{ .UserName }}</> <#C0DC7C>|</> <#51D1C9>у°Қ№ {{ .HostName }}</>",
          "type": "session"
        }
      ]
    },
    {
      "alignment": "left",
      "newline": true,
      "type": "prompt",
      "segments": [
        {
          "foreground": "",
          "style": "plain",
          "template": "в”Ӯ",
          "type": "text"
        },
        {
          "leading_diamond": "",
          "properties": {
            "folder_icon": " пҒј ",
            "folder_separator_icon": " <>пҒЎ</> ",
            "home_icon": "пҖ•",
            "style": "agnoster_short",
            "max_depth": 4,
            "right_format": "<u><b>%s</b></u>",
            "mapped_locations": {
              "~/Videos": "пҖ• <>пҒЎ</> пҖҪ",
              "~/Desktop": "пҖ• <>пҒЎ</> п„Ҳ",
              "~/Documents": "пҖ• <>пҒЎ</> у°Ҳҷ",
              "~/Downloads": "пҖ• <>пҒЎ</> пҖҷ",
              "~/Pictures/": "пҖ• <>пҒЎ</> пҖҫ",
              "~/Music": "пҖ• <>пҒЎ</> пҖҒ"
            }
          },
          "style": "diamond",
          "template": "  <#8ACE9C>{{ if not .Writable }}<#CE8A8A>пӮң {{ end }}{{ if .RootDir }}оҲ–{{ else }}{{ .Path }}{{ end }}</> ",
          "type": "path"
        }
      ]
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "",
          "style": "plain",
          "template": "в•°в”Җ",
          "type": "text"
        },
        {
          "foreground": "",
          "properties": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "вқҜ ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "osc99": true,
  "transient_prompt": {
    "background": "transparent",
    "foreground": "#FEF5ED",
    "template": "оҠ… "
  },
  "secondary_prompt": {
    "background": "transparent",
    "foreground": "",
    "template": "в•°в”ҖвқҜ "
  },
  "version": 3
}